
# -------------------------------------------------
# PetFinder - Git Ignore
# Ignore generated files, IDE settings, logs,
# and local configuration files.
# -------------------------------------------------

# Build Output
target/
build/
out/
bin/

*.class
*.jar
*.war
*.ear

# Logs
logs/
*.log

# Eclipse
.project
.classpath
.settings/

# IntelliJ IDEA
.idea/
*.iml

# VS Code
.vscode/

# Operating System Files
.DS_Store
Thumbs.db
Desktop.ini

# Environment Variables
.env
.env.*

# Spring Boot Profiles
application-local.properties
application-dev.properties
application-prod.properties

# Node.js (Future React Frontend)
node_modules/

# Temporary Files
*.tmp
*.temp
*.swp
*.bak

# Test Reports
coverage/

# Archive Files
*.zip
*.tar
*.gz
*.rar

